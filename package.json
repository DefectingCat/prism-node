{
  "name": "prism-node",
  "version": "0.1.0",
  "description": "",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "tsc": "tsc",
    "build": "tsc",
    "build:bin": "bun build src/main.ts --compile --outfile prism-node",
    "dev": "tsx src/main.ts -c ./config-dev.json",
    "start": "bun dist/main.js",
    "start:bin": "./prism-node",
    "watch": "tsc --watch",
    "fix": "biome format --write . && biome lint --write . && biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@types/yargs": "^17.0.35",
    "json5": "^2.2.3",
    "socks": "^2.8.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yargs": "^18.0.0"
  }
}